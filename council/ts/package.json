{
  "name": "@jorisjonkers-dev/council",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript council orchestrator package scaffold.",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.4",
  "scripts": {
    "build": "node scripts/build.mjs",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "lint": "eslint .",
    "test": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "22.20.0",
    "@vitest/coverage-v8": "4.1.9",
    "dependency-cruiser": "^17.0.1",
    "esbuild": "0.28.1",
    "eslint": "9.39.4",
    "prettier": "3.8.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  }
}
