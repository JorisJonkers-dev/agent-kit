{
  "$id": "agent-kit.agent-runner.runtime-package.schema.json",
  "title": "AgentRuntimePackage",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "artifact", "build", "runtime", "handoff"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "agent-kit.runtime/v1alpha1"
    },
    "kind": {
      "const": "AgentRuntimePackage"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifact": {
      "type": "object",
      "required": ["repository", "mediaType", "tagPattern", "releaseAssetPattern", "digestAlgorithm"],
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string"
        },
        "mediaType": {
          "type": "string"
        },
        "tagPattern": {
          "type": "string"
        },
        "releaseAssetPattern": {
          "type": "string"
        },
        "digestAlgorithm": {
          "const": "sha256"
        }
      }
    },
    "build": {
      "type": "object",
      "required": ["containerfile", "context", "args", "requiredBaseExecutables", "requiredAgentExecutables"],
      "additionalProperties": false,
      "properties": {
        "containerfile": {
          "type": "string"
        },
        "context": {
          "type": "string"
        },
        "args": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "requiredBaseExecutables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredAgentExecutables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optionalExecutables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "required": [
        "supportedAgents",
        "parityPolicy",
        "paths",
        "entrypoint",
        "repositories",
        "githubTokenHelper",
        "mcpProfiles",
        "attachmentProfiles",
        "sddSeed"
      ],
      "additionalProperties": true,
      "properties": {
        "supportedAgents": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["id", "homeEnv"],
            "additionalProperties": true,
            "properties": {
              "id": {
                "type": "string"
              },
              "homeEnv": {
                "type": "string"
              },
              "unsupportedReason": {
                "type": "string"
              }
            }
          }
        },
        "parityPolicy": {
          "type": "object",
          "required": ["requiresExplicitUnsupportedReason"],
          "additionalProperties": false,
          "properties": {
            "requiresExplicitUnsupportedReason": {
              "type": "boolean"
            }
          }
        },
        "paths": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "entrypoint": {
          "type": "object",
          "required": ["path", "command", "environment", "selfTests"],
          "additionalProperties": true,
          "properties": {
            "path": {
              "type": "string"
            },
            "command": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "environment": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/envVar"
              }
            },
            "selfTests": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "repositories": {
          "type": "object",
          "required": ["primaryUrlEnv", "primaryBranchEnv", "additionalUrlsEnv", "allowListOutputEnv", "gitHostEnv"],
          "additionalProperties": true
        },
        "githubTokenHelper": {
          "type": "object",
          "required": ["helperPath", "ghWrapperPath", "gitCredentialHelperPath", "mcpWrapperPath", "tokenUrlEnv", "tokenBearerEnv", "hostEnv"],
          "additionalProperties": true
        },
        "mcpProfiles": {
          "type": "object",
          "required": ["profileEnv", "profileDirectoryEnv", "placeholders", "profiles"],
          "additionalProperties": true,
          "properties": {
            "placeholders": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "env"],
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "env": {
                    "type": "string"
                  }
                }
              }
            },
            "profiles": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "claude", "codex"],
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "claude": {
                    "type": "string"
                  },
                  "codex": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "attachmentProfiles": {
          "type": "object",
          "required": ["profiles"],
          "additionalProperties": false,
          "properties": {
            "active": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "profiles": {
                  "$ref": "#/$defs/activeAttachmentSet"
                },
                "skillCards": {
                  "$ref": "#/$defs/activeAttachmentSet"
                },
                "fullSkills": {
                  "$ref": "#/$defs/activeAttachmentSet"
                }
              }
            },
            "profiles": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/attachmentProfile"
              }
            }
          }
        },
        "sddSeed": {
          "type": "object",
          "required": ["sourcePathEnv", "markerFileEnv", "updatePolicy"],
          "additionalProperties": false,
          "properties": {
            "sourcePathEnv": {
              "type": "string"
            },
            "markerFileEnv": {
              "type": "string"
            },
            "updatePolicy": {
              "enum": ["update-if-unmodified"]
            }
          }
        }
      }
    },
    "handoff": {
      "type": "object",
      "required": ["platformBlueprintResponsibilities", "forbiddenRuntimeDefaults"],
      "additionalProperties": false,
      "properties": {
        "platformBlueprintResponsibilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbiddenRuntimeDefaults": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "activeAttachmentSet": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "attachmentProfile": {
      "type": "object",
      "required": ["name", "mcpProfile", "skillCards", "fullSkills"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "mcpProfile": {
          "type": "string",
          "minLength": 1
        },
        "skillCards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attachmentSkillCard"
          }
        },
        "fullSkills": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "attachmentSkillCard": {
      "type": "object",
      "required": [
        "name",
        "purpose",
        "positiveTriggers",
        "negativeTriggers",
        "requiredMcpProfile",
        "risk",
        "expectedOutputs"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\r\\n]+$"
        },
        "positiveTriggers": {
          "$ref": "#/$defs/routingCardSignals"
        },
        "negativeTriggers": {
          "$ref": "#/$defs/routingCardSignals"
        },
        "requiredMcpProfile": {
          "type": "string",
          "minLength": 1
        },
        "risk": {
          "enum": ["low", "medium", "high"]
        },
        "expectedOutputs": {
          "$ref": "#/$defs/routingCardSignals"
        }
      }
    },
    "routingCardSignals": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "envVar": {
      "type": "object",
      "required": ["name", "required", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
