ARG AGENT_RUNNER_BASE_IMAGE
FROM ${AGENT_RUNNER_BASE_IMAGE}

ARG AGENT_RUNNER_BIN_DIR=/usr/local/bin
ARG AGENT_MCP_DIR=/etc/agent-mcp

RUN set -eu; \
  if ! command -v node >/dev/null 2>&1; then \
    if command -v apt-get >/dev/null 2>&1; then \
      apt-get update; \
      apt-get install -y --no-install-recommends nodejs npm; \
      rm -rf /var/lib/apt/lists/*; \
    elif command -v apk >/dev/null 2>&1; then \
      apk add --no-cache nodejs npm; \
    elif command -v dnf >/dev/null 2>&1; then \
      dnf install -y nodejs npm; \
      dnf clean all; \
    elif command -v microdnf >/dev/null 2>&1; then \
      microdnf install -y nodejs npm; \
      microdnf clean all; \
    elif command -v yum >/dev/null 2>&1; then \
      yum install -y nodejs npm; \
      yum clean all; \
    else \
      echo "Node >=22 is required but no supported package manager is available" >&2; \
      exit 1; \
    fi; \
  fi; \
  node_major="$(node --version | sed 's/^v//; s/\..*//')"; \
  case "${node_major}" in \
    ""|*[!0-9]*) echo "Could not parse Node version: $(node --version)" >&2; exit 1 ;; \
  esac; \
  if [ "${node_major}" -lt 22 ]; then \
    echo "Node >=22 is required; found $(node --version)" >&2; \
    exit 1; \
  fi

COPY entrypoint.sh ${AGENT_RUNNER_BIN_DIR}/agent-runner-entrypoint
COPY bin/agent-github-token ${AGENT_RUNNER_BIN_DIR}/agent-github-token
COPY bin/gh-wrapper ${AGENT_RUNNER_BIN_DIR}/gh-wrapper
COPY bin/git-credential-agent-gh-app ${AGENT_RUNNER_BIN_DIR}/git-credential-agent-gh-app
COPY bin/gh-mcp-wrapper ${AGENT_RUNNER_BIN_DIR}/gh-mcp-wrapper
COPY mcp/ ${AGENT_MCP_DIR}/

ENV AGENT_MCP_DIR=${AGENT_MCP_DIR}
ENV PATH=${AGENT_RUNNER_BIN_DIR}:$PATH

ENTRYPOINT ["agent-runner-entrypoint"]
