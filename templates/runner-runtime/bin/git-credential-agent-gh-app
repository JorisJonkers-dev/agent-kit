#!/usr/bin/env bash
set -u

TOKEN_HELPER="${AGENT_GITHUB_TOKEN_HELPER:-agent-github-token}"

action="${1:-}"
[ "$action" = "get" ] || exit 0

protocol=""
host=""
path=""
while IFS='=' read -r key value; do
  [ -n "$key" ] || break
  case "$key" in
    protocol) protocol="$value" ;;
    host) host="$value" ;;
    path) path="$value" ;;
  esac
done

[ "$protocol" = "https" ] || exit 0
[ -n "${AGENT_GIT_HOST:-}" ] || exit 0
[ "$host" = "$AGENT_GIT_HOST" ] || exit 0

requested_slug="${path%.git}"

if [ -n "${REPO_ALLOW:-}" ]; then
  [ -n "$requested_slug" ] || exit 0
  allowed=0
  for slug in $REPO_ALLOW; do
    [ "$requested_slug" = "$slug" ] && allowed=1 && break
  done
  [ "$allowed" = 1 ] || exit 0
  token=$(AGENT_GITHUB_REPO_URL="${AGENT_GIT_SCHEME:-https}://${host}/${requested_slug}" "$TOKEN_HELPER" 2>/dev/null) || exit 0
else
  primary_slug=""
  if [ -n "${REPO_URL:-}" ]; then
    primary_slug=$(AGENT_GIT_HOST="$host" "$TOKEN_HELPER" --print-slug "$REPO_URL" 2>/dev/null || true)
  fi
  if [ -n "$requested_slug" ] && [ -n "$primary_slug" ]; then
    [ "$requested_slug" = "$primary_slug" ] || exit 0
  fi
  token=$("$TOKEN_HELPER" 2>/dev/null) || exit 0
fi

[ -n "$token" ] || exit 0

printf 'username=x-access-token\n'
printf 'password=%s\n\n' "$token"
