{
  "knowledge": {
    "type": "http",
    "url": "@KNOWLEDGE_MCP_URL@/mcp",
    "headers": {
      "Authorization": "Bearer @KNOWLEDGE_MCP_BEARER_TOKEN@"
    }
  },
  "git-host": {
    "type": "stdio",
    "command": "gh-mcp-wrapper"
  },
  "frontend-docs": {
    "type": "http",
    "url": "@FRONTEND_DOCS_MCP_URL@"
  },
  "ui-docs": {
    "type": "http",
    "url": "@UI_DOCS_MCP_URL@"
  },
  "playwright": {
    "type": "stdio",
    "command": "playwright-mcp",
    "args": ["--headless", "--browser", "chromium"]
  },
  "cluster": {
    "type": "http",
    "url": "@CLUSTER_MCP_URL@"
  },
  "code-intel": {
    "type": "stdio",
    "command": "serena",
    "args": [
      "start-mcp-server",
      "--project-from-cwd",
      "--mode",
      "no-memories",
      "--open-web-dashboard",
      "false"
    ]
  }
}
